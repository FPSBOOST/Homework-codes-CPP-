#include <iostream>
#include <cmath>
using namespace std;

 bool primo(int n) {
     if (n <= 1) {
         return 0;
     }
     for (int i = 2; i <= sqrt(n); i++) {

         if (n % i == 0) return false;

     }

     return true;
 }


int main() {
     int num;
    cout << " Numero: " << endl;
     cin >> num;

     if (primo(num)) {
         cout << " Primo" << endl;

     }else {
         cout << " Nao Primo" << endl;
     }
     return 0;
}
