#include <iostream>
using namespace std;

    long long somarPares(int n) {
        long long soma = 0;
        for (int i = 2; i <= n; i += 2) {
            soma += i;
        }
    return soma;
    }

int main() {

        int limite;

        cout << "Coloque o valor de n: ";
        cin >> limite;

        cout << somarPares(limite) << endl;

        return 0;
    }



